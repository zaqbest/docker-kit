# ===================================================================
# 集中管理所有服务的宿主端口，避免冲突。
# docker-compose 会自动读取本文件（同目录 .env）。
# 修改后需要 docker compose up -d --force-recreate <service> 生效。
#
# 端口段规划（避免与常用软件冲突）：
#   80 / 443            HTTP / HTTPS（nginx 反代入口）
#   33xx / 35xx         数据库
#   55xx / 56xx         Kibana / 观测类 UI
#   83xx / 85xx / 86xx  Consul / Nexus / Solr
#   90xx / 92xx / 93xx  Kafka / Elasticsearch / H2 JDBC
# ===================================================================

# --- nginx ---------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- consul --------------------------------------------------------
CONSUL_HTTP_PORT=8500
CONSUL_DNS_PORT=8600
CONSUL_SERVER_RPC_PORT=8300
CONSUL_SERF_LAN_PORT=8301
CONSUL_SERF_WAN_PORT=8302

# --- mysql ---------------------------------------------------------
MYSQL_PORT=3306

# --- nexus ---------------------------------------------------------
NEXUS_HTTP_PORT=8081
NEXUS_DOCKER_PORT=8085

# --- solr ----------------------------------------------------------
SOLR_HTTP_PORT=8983
SOLR_ZK_PORT=2182

# --- kafka ---------------------------------------------------------
# KRaft 模式，不再需要 ZooKeeper。
KAFKA_PORT=9092
# 与 SAP bizx 本地开发环境保持一致的资源上限；按机器情况调整。
KAFKA_MEMORY=2G

# --- elasticsearch / kibana ---------------------------------------
ELASTICSEARCH_HTTP_PORT=9200
ELASTICSEARCH_TRANSPORT_PORT=9300
KIBANA_PORT=5601

# --- h2 ------------------------------------------------------------
H2_TCP_PORT=1521
H2_WEB_PORT=81

# --- danmu-server -------------------------------------------------
# Misaka 弹幕服务器对外端口
DANMU_SERVER_PORT=7768

# ===================================================================
# 域名 / 主机名
# nginx server_name、kafka advertised listeners 等都从这里取值。
# 修改后需要重建对应容器：
#   nginx： docker compose -f docker-compose-nginx.yml up -d --force-recreate
#   kafka： docker compose -f docker-compose-kafka.yml up -d --force-recreate
# ===================================================================
BASE_DOMAIN=zaqbest.com
NEXUS_HOSTNAME=nexus.zaqbest.com
DANMU_HOSTNAME=danmu.zaqbest.com
KAFKA_HOSTNAME=kafka.zaqbest.com
SAP_HOSTNAME=sap.zaqbest.com

# ===================================================================
# TLS 证书套件
# 每个应用可独立选择 letsencrypt（默认，公网签发）或 selfsigned（本地自签）。
# 对应 certs/<profile>/server.crt + server.key + ca/public-ca.crt。
# 本地覆盖示例（.env.localtest）：
#   NEXUS_SSL_PROFILE=selfsigned
# ===================================================================
NEXUS_SSL_PROFILE=letsencrypt
DANMU_SSL_PROFILE=letsencrypt
ES_SSL_PROFILE=letsencrypt
KIBANA_SSL_PROFILE=letsencrypt
SAP_SSL_PROFILE=letsencrypt
