# 单节点模式
discovery.type=single-node
cluster.name=docker-kit-es
node.name=es01

# JVM 堆内存（按需调整）
ES_JAVA_OPTS=-Xms1g -Xmx1g

# 关闭机器内存锁，避免 Docker Desktop 权限问题
bootstrap.memory_lock=false

# 安全：账号密码 + HTTP TLS（复用 nginx 证书）
xpack.security.enabled=true
ELASTIC_PASSWORD=elastic

xpack.security.http.ssl.enabled=true
xpack.security.http.ssl.certificate=certs/server.crt
xpack.security.http.ssl.key=certs/server.key

# 节点间 transport SSL 单节点不需要，关掉简化配置
xpack.security.transport.ssl.enabled=false
