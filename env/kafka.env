# =====================================================================
# Kafka (bitnami 3.8.1, KRaft 模式)
# 与 SAP bizx 本地开发环境的 kafka 配置保持一致。
# 参考: /Users/C5388584/SAPDevelop/sfsf/tools/bizx-docker-dev/docker-compose.yml
# =====================================================================

# --- 消息大小 --------------------------------------------------------
# https://www.confluent.io/learn/kafka-message-size-limit/
KAFKA_CFG_MAX_REQUEST_SIZE=20971520      # 20 MB
KAFKA_SOCKET_REQUEST_MAX_BYTES=52428800  # 50 MB
KAFKA_MESSAGE_MAX_BYTES=10485760         # 10 MB

# --- KRaft (取代 ZooKeeper) -----------------------------------------
KAFKA_ENABLE_KRAFT=yes
KAFKA_CFG_NODE_ID=0
KAFKA_CFG_PROCESS_ROLES=controller,broker
KAFKA_CFG_CONTROLLER_QUORUM_VOTERS=0@kafka:9093
KAFKA_KRAFT_CLUSTER_ID=kraft-cluster-bizx

# --- Listeners -------------------------------------------------------
# 9092 供客户端连接（外部走 SASL_PLAINTEXT），9093 供控制器内部通信。
# KAFKA_CFG_ADVERTISED_LISTENERS 在 compose 文件里注入（用到 ${KAFKA_HOSTNAME}）。
KAFKA_CFG_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_CFG_LISTENERS=SASL_PLAINTEXT://kafka:9092,CONTROLLER://kafka:9093
KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:SASL_PLAINTEXT,SASL_PLAINTEXT:SASL_PLAINTEXT
KAFKA_CFG_SECURITY_INTER_BROKER_PROTOCOL=SASL_PLAINTEXT
KAFKA_CLIENT_LISTENER_NAME=SASL_PLAINTEXT

# --- SASL 认证 -------------------------------------------------------
KAFKA_CFG_SASL_ENABLED_MECHANISMS=PLAIN,SCRAM-SHA-256,SCRAM-SHA-512
KAFKA_CFG_SASL_JAAS_CONFIG='org.apache.kafka.common.security.scram.ScramLoginModule required username="sebadmin" password="local123!";'
KAFKA_CFG_SASL_MECHANISM_CLIENT_PROTOCOL=SCRAM-SHA-512
KAFKA_CFG_SASL_MECHANISM_CONTROLLER_PROTOCOL=PLAIN
KAFKA_CFG_SASL_MECHANISM_INTER_BROKER_PROTOCOL=SCRAM-SHA-512

# --- 账号（客户端 / broker 间 / controller 间共用一套）---------------
KAFKA_CLIENT_USERS=sebadmin
KAFKA_CLIENT_PASSWORDS=local123!
KAFKA_CONTROLLER_USER=sebadmin
KAFKA_CONTROLLER_PASSWORD=local123!
KAFKA_INTER_BROKER_USER=sebadmin
KAFKA_INTER_BROKER_PASSWORD=local123!

# --- 其它 ------------------------------------------------------------
KAFKA_CFG_CONNECTIONS_MAX_IDLE_MS=7200000
