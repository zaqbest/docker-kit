SERVER_NAME=kibana
SERVER_HOST=0.0.0.0

# Kibana 自身开启 HTTPS（复用 Let's Encrypt 签发的通配证书）
SERVER_SSL_ENABLED=true
SERVER_SSL_CERTIFICATE=/usr/share/kibana/config/certs/server.crt
SERVER_SSL_KEY=/usr/share/kibana/config/certs/server.key

# ES 走 HTTPS，复用同一套证书
ELASTICSEARCH_HOSTS=https://elasticsearch:9200
ELASTICSEARCH_USERNAME=kibana_system
ELASTICSEARCH_PASSWORD=kibana_system

# ES 证书是 Let's Encrypt 签的公网证书,直接走 Kibana(Node.js)自带的
# Mozilla CA 信任库即可,无需显式指定 certificateAuthorities。
# 显式指定反而会覆盖系统信任库 —— 曾试过配 --ca-file 导出的 intermediate+root,
# 但 LE 新根(ISRG Root YR)是交叉签版本,单独放会因为找不到自锚根报
# "unable to get issuer certificate";走系统库最省心。
#
# certificate 模式:校验证书链,不校验 hostname(容器间用 `elasticsearch` 服务名互访,
# 而证书 SAN 是 *.zaqbest.com,不匹配)。
ELASTICSEARCH_SSL_VERIFICATIONMODE=certificate
